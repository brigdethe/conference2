<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>Feedback Survey | Ghana Competition Law & Policy Seminar</title>
    <meta content="Share your feedback on the Ghana Competition Law & Policy Seminar" name="description" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link href="https://ik.imagekit.io/dr5fryhth/conference/imglogo?updatedAt=1769778325875" rel="shortcut icon"
        type="image/x-icon" />
    <style>
        @font-face {
            font-family: 'Neuemontreal';
            src: url('https://cdn.prod.website-files.com/68eee3b7aa1d9628fd1f8ee0/68f15cac5a8972841fd35472_PPNeueMontreal-Regular.woff') format('woff');
            font-weight: normal;
            font-display: swap;
        }

        @font-face {
            font-family: 'Seasonmix';
            src: url('https://cdn.prod.website-files.com/68eee3b7aa1d9628fd1f8ee0/68f15cc2a525239513fc686d_SeasonMix-Regular.woff') format('woff');
            font-weight: normal;
            font-display: swap;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; }
        body, button, input, textarea, select { font-family: 'Neuemontreal', Arial, sans-serif; }
        body { background-color: #f3f4f6; color: #1f2937; min-height: 100vh; }

        .grid-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            width: 100%;
            min-height: 100vh;
        }

        .left-column {
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .left-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://ik.imagekit.io/dr5fryhth/conferencenew/giammarco-boscaro-zeH-ljawHtg-unsplash.jpg?updatedAt=1770793618312');
            background-size: cover;
            background-position: center;
            filter: brightness(0.35);
        }

        .left-content {
            position: relative;
            z-index: 2;
            color: #fff;
            padding: 3rem;
            max-width: 480px;
        }

        .left-content h1 {
            font-family: 'Seasonmix', Arial, sans-serif;
            font-size: 2.5rem;
            font-weight: normal;
            margin-bottom: 1rem;
            line-height: 1.1;
        }

        .left-content p {
            font-size: 1.05rem;
            opacity: 0.85;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }

        .progress-steps {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .progress-step {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            opacity: 0.5;
            transition: opacity 0.3s;
        }

        .progress-step.active, .progress-step.done {
            opacity: 1;
        }

        .step-circle {
            width: 28px;
            height: 28px;
            border: 2px solid rgba(255,255,255,0.5);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            flex-shrink: 0;
            transition: all 0.3s;
        }

        .progress-step.active .step-circle {
            border-color: #fbbf24;
            background: #fbbf24;
            color: #1a365d;
        }

        .progress-step.done .step-circle {
            border-color: #10b981;
            background: #10b981;
            color: #fff;
        }

        .step-label {
            font-size: 0.9rem;
            font-weight: 500;
        }

        .right-column {
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            overflow-y: auto;
        }

        .survey-card {
            width: 100%;
            max-width: 480px;
            padding: 2rem 0;
        }

        .question-slide {
            display: none;
            animation: fadeIn 0.3s ease;
        }

        .question-slide.active { display: block; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .q-number {
            font-size: 0.8rem;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.5rem;
        }

        .q-text {
            font-family: 'Seasonmix', Arial, sans-serif;
            font-size: 1.5rem;
            color: #111827;
            margin-bottom: 1.75rem;
            line-height: 1.25;
        }

        /* Number Rating (Q1) */
        .number-scale { display: flex; gap: 0.5rem; justify-content: center; margin-bottom: 0.25rem; }
        .number-btn {
            width: 52px; height: 52px; border: 2px solid #e5e7eb; background: #fff;
            font-size: 1.25rem; font-weight: 700; cursor: pointer; border-radius: 12px;
            color: #6b7280; transition: all 0.25s ease; display: flex;
            align-items: center; justify-content: center;
        }
        .number-btn:hover { border-color: #6b7280; background: #f9fafb; color: #374151; }
        .number-btn.active { border-color: #1a365d; background: #1a365d; color: #fff; }
        .scale-labels { display: flex; justify-content: space-between; font-size: 0.8rem; color: #9ca3af; margin-bottom: 0.5rem; }
        .scale-selected-label {
            text-align: center; font-size: 0.9rem; font-weight: 600;
            color: #6b7280; min-height: 24px; transition: all 0.3s;
        }
        .scale-selected-label.selected { color: #111827; }

        /* Option buttons (Q2, Q3) */
        .option-grid { display: flex; flex-direction: column; gap: 0.6rem; }
        .option-btn {
            padding: 14px 20px; border: 2px solid #e5e7eb; border-radius: 12px;
            background: #fff; font-size: 1rem; font-weight: 500; color: #374151;
            cursor: pointer; transition: all 0.2s; text-align: left;
            display: flex; align-items: center; gap: 12px;
        }
        .option-btn:hover { border-color: #6b7280; background: #f9fafb; }
        .option-btn.selected { border-color: #1a365d; background: #1a365d; color: #fff; }
        .option-icon { font-size: 1.2rem; }

        /* Likert scale (Q6) */
        .likert-scale { display: flex; flex-direction: column; gap: 0.5rem; }
        .likert-btn {
            padding: 12px 16px; border: 2px solid #e5e7eb; border-radius: 10px;
            background: #fff; font-size: 0.95rem; font-weight: 500; color: #374151;
            cursor: pointer; transition: all 0.2s; text-align: center;
        }
        .likert-btn:hover { border-color: #6b7280; }
        .likert-btn.selected { border-color: #1a365d; background: #1a365d; color: #fff; }

        /* Text inputs */
        .text-input {
            width: 100%; padding: 14px 16px; border: 2px solid #e5e7eb;
            border-radius: 12px; font-size: 1rem; font-family: inherit;
            resize: vertical; min-height: 90px; transition: border-color 0.2s;
        }
        .text-input:focus { outline: none; border-color: #1a365d; }
        .text-input::placeholder { color: #9ca3af; }

        .conditional-field { display: none; margin-top: 12px; animation: fadeIn 0.3s; }
        .conditional-field.show { display: block; }

        /* Nav buttons */
        .nav-row { display: flex; gap: 12px; margin-top: 2rem; }
        .btn {
            flex: 1; padding: 14px 20px; border: none; border-radius: 12px;
            font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.2s;
        }
        .btn-back { background: #f3f4f6; color: #374151; }
        .btn-back:hover { background: #e5e7eb; }
        .btn-next { background: #1a365d; color: #fff; }
        .btn-next:hover { background: #2d4a7c; }
        .btn-next:disabled { background: #d1d5db; cursor: not-allowed; }
        .btn-submit { background: #059669; color: #fff; }
        .btn-submit:hover { background: #047857; }
        .btn-submit:disabled { background: #d1d5db; cursor: not-allowed; }

        /* Success screen */
        .success-screen, .invalid-screen, .submitted-screen {
            display: none; flex-direction: column; align-items: center;
            justify-content: center; text-align: center; padding: 2rem;
        }
        .success-screen.show, .invalid-screen.show, .submitted-screen.show { display: flex; }

        .success-icon {
            width: 72px; height: 72px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.5rem; animation: pop 0.5s ease;
        }
        @keyframes pop { 0%{transform:scale(0)} 50%{transform:scale(1.2)} 100%{transform:scale(1)} }

        .success-icon.green { background: #059669; }
        .success-icon.yellow { background: #fbbf24; }
        .success-icon.red { background: #ef4444; }
        .success-icon svg { width: 36px; height: 36px; color: #fff; }

        .success-title { font-family: 'Seasonmix', Arial, sans-serif; font-size: 1.75rem; color: #111827; margin-bottom: 0.75rem; }
        .success-msg { font-size: 1rem; color: #6b7280; line-height: 1.6; max-width: 360px; }

        .loading-overlay {
            display: none; position: absolute; inset: 0; background: rgba(255,255,255,0.85);
            align-items: center; justify-content: center; z-index: 100;
        }
        .loading-overlay.show { display: flex; }
        .spinner {
            width: 36px; height: 36px; border: 3px solid #e5e7eb;
            border-top-color: #1a365d; border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* Confetti canvas */
        .confetti { position: fixed; inset: 0; pointer-events: none; z-index: 1000; }

        @media (max-width: 768px) {
            .grid-container { grid-template-columns: 1fr; }
            .left-column { min-height: 220px; }
            .left-content { padding: 1.5rem; }
            .left-content h1 { font-size: 1.75rem; }
            .progress-steps { display: none; }
            .right-column { padding: 1.5rem; }
            .q-text { font-size: 1.25rem; }
            .emoji-btn { width: 44px; height: 44px; font-size: 1.6rem; }
        }
    </style>
</head>

<body>
    <div class="grid-container">
        <div class="left-column">
            <div class="left-bg"></div>
            <div class="left-content">
                <h1>Help Us Improve</h1>
                <p>Your candid feedback helps us make future seminars even better. It only takes 2 minutes.</p>
                <div class="progress-steps" id="progressSteps">
                    <div class="progress-step active" data-step="1">
                        <div class="step-circle">1</div>
                        <span class="step-label">Expectations</span>
                    </div>
                    <div class="progress-step" data-step="2">
                        <div class="step-circle">2</div>
                        <span class="step-label">Clarity</span>
                    </div>
                    <div class="progress-step" data-step="3">
                        <div class="step-circle">3</div>
                        <span class="step-label">Pace</span>
                    </div>
                    <div class="progress-step" data-step="4">
                        <div class="step-circle">4</div>
                        <span class="step-label">Speakers</span>
                    </div>
                    <div class="progress-step" data-step="5">
                        <div class="step-circle">5</div>
                        <span class="step-label">Future Topics</span>
                    </div>
                    <div class="progress-step" data-step="6">
                        <div class="step-circle">6</div>
                        <span class="step-label">Attend Again</span>
                    </div>
                    <div class="progress-step" data-step="7">
                        <div class="step-circle">7</div>
                        <span class="step-label">Other Concerns</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="right-column" id="rightColumn">
            <div class="survey-card" id="surveyCard">
                <!-- Q1: Expectations (Number Scale) -->
                <div class="question-slide active" data-q="1">
                    <div class="q-number">Question 1 of 7</div>
                    <div class="q-text">Did the seminar meet your expectations?</div>
                    <div class="number-scale">
                        <button class="number-btn" data-value="Terrible" data-num="1" data-label="Not at all" onclick="selectNumber(this)">1</button>
                        <button class="number-btn" data-value="Poor" data-num="2" data-label="Slightly" onclick="selectNumber(this)">2</button>
                        <button class="number-btn" data-value="Okay" data-num="3" data-label="Moderately" onclick="selectNumber(this)">3</button>
                        <button class="number-btn" data-value="Good" data-num="4" data-label="Very much" onclick="selectNumber(this)">4</button>
                        <button class="number-btn" data-value="Amazing" data-num="5" data-label="Exceeded expectations" onclick="selectNumber(this)">5</button>
                    </div>
                    <div class="scale-labels"><span>Not at all</span><span>Exceeded expectations</span></div>
                    <div class="scale-selected-label" id="scaleLabel">Tap a number to rate</div>
                    <div class="nav-row">
                        <button class="btn btn-next" id="next1" disabled onclick="goTo(2)">Next</button>
                    </div>
                </div>

                <!-- Q2: Unclear Section -->
                <div class="question-slide" data-q="2">
                    <div class="q-number">Question 2 of 7</div>
                    <div class="q-text">Was there any section of the lecture you found unclear?</div>
                    <div class="option-grid">
                        <button class="option-btn" data-value="Yes" onclick="selectQ2(this,'Yes')"><span class="option-icon">✋</span> Yes</button>
                        <button class="option-btn" data-value="No" onclick="selectQ2(this,'No')"><span class="option-icon">👍</span> No, all clear</button>
                    </div>
                    <div class="conditional-field" id="q2TextField">
                        <textarea class="text-input" id="q2Text" placeholder="Which section was unclear?"></textarea>
                    </div>
                    <div class="nav-row">
                        <button class="btn btn-back" onclick="goTo(1)">Back</button>
                        <button class="btn btn-next" id="next2" disabled onclick="goTo(3)">Next</button>
                    </div>
                </div>

                <!-- Q3: Pace -->
                <div class="question-slide" data-q="3">
                    <div class="q-number">Question 3 of 7</div>
                    <div class="q-text">Was the presentation too slow or too quick?</div>
                    <div class="option-grid">
                        <button class="option-btn" data-value="Too Slow" onclick="selectOpt(this,'q3')"><span class="option-icon">🐢</span> Too Slow</button>
                        <button class="option-btn" data-value="Just Right" onclick="selectOpt(this,'q3')"><span class="option-icon">👌</span> Just Right</button>
                        <button class="option-btn" data-value="Too Fast" onclick="selectOpt(this,'q3')"><span class="option-icon">🚀</span> Too Fast</button>
                    </div>
                    <div class="nav-row">
                        <button class="btn btn-back" onclick="goTo(2)">Back</button>
                        <button class="btn btn-next" id="next3" disabled onclick="goTo(4)">Next</button>
                    </div>
                </div>

                <!-- Q4: Speaker Improvements -->
                <div class="question-slide" data-q="4">
                    <div class="q-number">Question 4 of 7</div>
                    <div class="q-text">What do you think the speakers could have done better?</div>
                    <textarea class="text-input" id="q4Text" placeholder="Share your thoughts... (optional)"></textarea>
                    <div class="nav-row">
                        <button class="btn btn-back" onclick="goTo(3)">Back</button>
                        <button class="btn btn-next" onclick="goTo(5)">Next</button>
                    </div>
                </div>

                <!-- Q5: Future Topics -->
                <div class="question-slide" data-q="5">
                    <div class="q-number">Question 5 of 7</div>
                    <div class="q-text">Any aspect of competition law you'd like discussed at a future lecture?</div>
                    <textarea class="text-input" id="q5Text" placeholder="Suggest topics... (optional)"></textarea>
                    <div class="nav-row">
                        <button class="btn btn-back" onclick="goTo(4)">Back</button>
                        <button class="btn btn-next" onclick="goTo(6)">Next</button>
                    </div>
                </div>

                <!-- Q6: Attend Again (Likert) -->
                <div class="question-slide" data-q="6">
                    <div class="q-number">Question 6 of 7</div>
                    <div class="q-text">How likely are you to attend another lecture by the Professors later this year?</div>
                    <div class="likert-scale">
                        <button class="likert-btn" data-value="Very Unlikely" onclick="selectLikert(this)">Very Unlikely</button>
                        <button class="likert-btn" data-value="Unlikely" onclick="selectLikert(this)">Unlikely</button>
                        <button class="likert-btn" data-value="Maybe" onclick="selectLikert(this)">Maybe</button>
                        <button class="likert-btn" data-value="Likely" onclick="selectLikert(this)">Likely</button>
                        <button class="likert-btn" data-value="Very Likely" onclick="selectLikert(this)">Very Likely</button>
                    </div>
                    <div class="nav-row">
                        <button class="btn btn-back" onclick="goTo(5)">Back</button>
                        <button class="btn btn-next" id="next6" disabled onclick="goTo(7)">Next</button>
                    </div>
                </div>

                <!-- Q7: Other Concerns -->
                <div class="question-slide" data-q="7">
                    <div class="q-number">Question 7 of 7</div>
                    <div class="q-text">Do you have any other questions or concerns?</div>
                    <textarea class="text-input" id="q7Text" placeholder="Share any other questions or concerns... (optional)"></textarea>
                    <div class="nav-row">
                        <button class="btn btn-back" onclick="goTo(6)">Back</button>
                        <button class="btn btn-submit" id="submitBtn" onclick="submitFeedback()">Submit</button>
                    </div>
                </div>

                <div class="loading-overlay" id="loadingOverlay"><div class="spinner"></div></div>
            </div>

            <!-- Success -->
            <div class="success-screen" id="successScreen">
                <div class="success-icon green">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                </div>
                <div class="success-title">Thank You!</div>
                <div class="success-msg">Your feedback has been submitted. We truly appreciate your time and insights.</div>
                <div class="documents-section" style="margin-top:2rem;width:100%;max-width:400px;">
                    <p style="font-size:0.95rem;font-weight:600;color:#374151;margin-bottom:0.75rem;">Seminar Documents</p>
                    <p style="font-size:0.85rem;color:#6b7280;margin-bottom:1rem;">Access the seminar materials below:</p>
                    <div style="display:flex;flex-direction:column;gap:0.5rem;">
                        <a href="/api/documents/competition-policy-and-law-concept" target="_blank" style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:#f8f9fa;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:#1a365d;font-size:0.9rem;font-weight:500;transition:all 0.2s;">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#1a365d" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                            Competition Policy and Law Concept
                        </a>
                        <a href="/api/documents/chairmans-remarks" target="_blank" style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:#f8f9fa;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:#1a365d;font-size:0.9rem;font-weight:500;transition:all 0.2s;">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#1a365d" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                            Chairman's Remarks
                        </a>
                        <a href="/api/documents/guest-speaker-speech" target="_blank" style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:#f8f9fa;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:#1a365d;font-size:0.9rem;font-weight:500;transition:all 0.2s;">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#1a365d" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                            Guest Speaker Speech
                        </a>
                    </div>
                </div>
            </div>

            <!-- Already submitted -->
            <div class="submitted-screen" id="submittedScreen">
                <div class="success-icon yellow">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="success-title">Already Submitted</div>
                <div class="success-msg">You have already submitted feedback. Thank you for your participation!</div>
            </div>

            <!-- Invalid token -->
            <div class="invalid-screen" id="invalidScreen">
                <div class="success-icon red">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
                </div>
                <div class="success-title">Invalid Link</div>
                <div class="success-msg">This survey link is not valid. Please use the link sent to your email or phone.</div>
            </div>
        </div>
    </div>

    <canvas class="confetti" id="confetti"></canvas>

    <script src="https://openfpcdn.io/fingerprintjs/v4"></script>
    <script>
        const params = new URLSearchParams(window.location.search);
        let surveyToken = params.get('token');
        let isAnonymous = false;
        const answers = { q1: null, q2_had_unclear: null, q3: null, q6: null };

        async function init() {
            if (!surveyToken) {
                // No token — use FingerprintJS for anonymous submission
                try {
                    const fp = await FingerprintJS.load();
                    const result = await fp.get();
                    surveyToken = 'fp_' + result.visitorId;
                    isAnonymous = true;
                } catch (e) {
                    console.error('Fingerprint error:', e);
                    // Fallback: generate a random token
                    surveyToken = 'fp_' + Math.random().toString(36).substring(2) + Date.now().toString(36);
                    isAnonymous = true;
                }
            }

            try {
                const res = await fetch('/api/feedback/check/' + surveyToken);
                const data = await res.json();
                if (!data.valid) {
                    document.getElementById('surveyCard').style.display = 'none';
                    document.getElementById('invalidScreen').classList.add('show');
                } else if (data.submitted) {
                    document.getElementById('surveyCard').style.display = 'none';
                    document.getElementById('submittedScreen').classList.add('show');
                } else if (!isAnonymous) {
                    // Record that the invited link was opened
                    fetch('/api/feedback/opened/' + surveyToken, { method: 'POST' }).catch(() => {});
                }
            } catch (e) {
                console.error('Check error:', e);
            }
        }
        init();

        function goTo(num) {
            document.querySelectorAll('.question-slide').forEach(s => s.classList.remove('active'));
            document.querySelector('[data-q="' + num + '"]').classList.add('active');
            document.querySelectorAll('.progress-step').forEach(s => {
                const sn = parseInt(s.dataset.step);
                s.classList.remove('active', 'done');
                if (sn < num) s.classList.add('done');
                else if (sn === num) s.classList.add('active');
            });
        }

        function selectNumber(btn) {
            document.querySelectorAll('.number-btn').forEach(b => {
                b.classList.toggle('active', parseInt(b.dataset.num) <= parseInt(btn.dataset.num));
            });
            answers.q1 = btn.dataset.value;
            document.getElementById('scaleLabel').textContent = btn.dataset.label;
            document.getElementById('scaleLabel').classList.add('selected');
            document.getElementById('next1').disabled = false;
        }

        function selectQ2(btn, val) {
            btn.closest('.option-grid').querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            answers.q2_had_unclear = val;
            const tf = document.getElementById('q2TextField');
            if (val === 'Yes') tf.classList.add('show'); else { tf.classList.remove('show'); document.getElementById('q2Text').value = ''; }
            document.getElementById('next2').disabled = false;
        }

        function selectOpt(btn, qKey) {
            btn.closest('.option-grid').querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            answers[qKey] = btn.dataset.value;
            const nextBtn = document.getElementById('next' + btn.closest('.question-slide').dataset.q);
            if (nextBtn) nextBtn.disabled = false;
        }

        function selectLikert(btn) {
            btn.closest('.likert-scale').querySelectorAll('.likert-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            answers.q6 = btn.dataset.value;
            document.getElementById('next6').disabled = false;
        }

        async function submitFeedback() {
            document.getElementById('loadingOverlay').classList.add('show');
            const payload = {
                survey_token: surveyToken,
                q1_expectations: answers.q1,
                q2_had_unclear: answers.q2_had_unclear,
                q2_unclear_section: answers.q2_had_unclear === 'Yes' ? document.getElementById('q2Text').value : null,
                q3_pace: answers.q3,
                q4_speaker_improvements: document.getElementById('q4Text').value || null,
                q5_future_topics: document.getElementById('q5Text').value || null,
                q6_attend_again: answers.q6,
                q7_other_concerns: document.getElementById('q7Text').value || null,
                source: isAnonymous ? 'anonymous' : 'invited'
            };
            try {
                const res = await fetch('/api/feedback', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                document.getElementById('loadingOverlay').classList.remove('show');
                if (res.ok) {
                    document.getElementById('surveyCard').style.display = 'none';
                    document.getElementById('successScreen').classList.add('show');
                    launchConfetti();
                } else {
                    alert(data.detail || 'An error occurred.');
                }
            } catch (e) {
                document.getElementById('loadingOverlay').classList.remove('show');
                alert('An error occurred. Please try again.');
            }
        }

        function launchConfetti() {
            const c = document.getElementById('confetti'), ctx = c.getContext('2d');
            c.width = window.innerWidth; c.height = window.innerHeight;
            const pieces = [], colors = ['#1a365d','#fbbf24','#10b981','#ef4444','#8b5cf6','#ec4899'];
            for (let i = 0; i < 120; i++) pieces.push({
                x: Math.random()*c.width, y: Math.random()*c.height - c.height,
                w: Math.random()*10+5, h: Math.random()*6+3,
                color: colors[Math.floor(Math.random()*colors.length)],
                rot: Math.random()*360, rs: Math.random()*10-5,
                sy: Math.random()*3+2, sx: Math.random()*2-1, op: 1
            });
            function draw() {
                ctx.clearRect(0,0,c.width,c.height);
                let alive = false;
                pieces.forEach(p => {
                    if (p.op <= 0) return; alive = true;
                    ctx.save(); ctx.translate(p.x+p.w/2, p.y+p.h/2);
                    ctx.rotate(p.rot*Math.PI/180); ctx.globalAlpha = p.op;
                    ctx.fillStyle = p.color; ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
                    ctx.restore();
                    p.y += p.sy; p.x += p.sx; p.rot += p.rs;
                    if (p.y > c.height) p.op -= 0.02;
                });
                if (alive) requestAnimationFrame(draw);
            }
            draw();
        }
    </script>
</body>
</html>
